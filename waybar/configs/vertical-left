{
    "layer": "top",
    "position": "left",
    "width": 45,
    "height": 0,
    "margin-top": 8,
    "margin-bottom": 8,
    "margin-left": 3,
    "modules-left": ["group/top"],
    "modules-center": ["group/middle"],
    "modules-right": ["group/bottom"],

    "group/top": {
        "orientation": "inherit",
        "modules": ["idle_inhibitor", "tray", "hyprland/workspaces"]
    },
    "group/middle": {
        "orientation": "inherit",
        "modules": ["hyprland/window"]
    },
    "group/bottom": {
        "orientation": "inherit",
        "modules": ["network", "clock", "battery", "pulseaudio", "custom/notification", "custom/power"]
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": { "activated": "●", "deactivated": "○" }
    },
    "tray": { "icon-size": 14, "spacing": 10 },
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "一", "2": "二", "3": "三", "4": "四", "5": "五",
            "6": "六", "7": "七", "8": "八", "9": "九", "10": "十"
        },
        "persistent-workspaces": { "*": 5 }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 20,
        "separate-outputs": true,
        "rotate": 90
    },

    "network": {
        "format-wifi": "    {essid}",
        "format-ethernet": "    LAN",
        "format-disconnected": "    Off",
        "tooltip-format": "{essid} ({signalStrength}%)\n{ipaddr}",
        "rotate": 90
    },
    "clock": {
        "interval": 1,
        "format": "{:%I:%M %p} ",
        "tooltip-format": "{:%A, %B %d, %Y}",
        "rotate": 90
    },
    "battery": {
        "format": "    {capacity}%",
        "format-charging": "    {capacity}%",
        "tooltip-format": "{capacity}%",
        "rotate": 90
    },
    "pulseaudio": {
        "format": "    {volume}%",
        "format-muted": "    Mute",
        "tooltip-format": "{volume}%",
        "on-click": "pavucontrol",
        "rotate": 90
    },
    "custom/notification": {
        "format": "",
        "on-click": "swaync-client -t -sw",
        "tooltip": false,
        "rotate": 90,
        "min-length": 3
    },
    "custom/power": {
        "format": "",
        "on-click": "wlogout",
        "rotate": 90,
        "min-length": 2
    }
}

